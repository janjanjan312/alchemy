# --- AI API Keys ---
ARK_API_KEY=your_ark_api_key
VITE_ARK_TEXT_MODEL=deepseek-v3-250324
DASHSCOPE_API_KEY=your_dashscope_api_key

# --- Database (Turso / libSQL) ---
# Local dev: file:psyche.db
# Production: libsql://your-db-name-your-org.turso.io
TURSO_DATABASE_URL=file:psyche.db
TURSO_AUTH_TOKEN=

# --- ASR (Speech Recognition) ---
# Set VITE_ prefixed vars so the client connects directly to external ASR servers
# bypassing the local WebSocket proxy (required for Vercel deployment)
VITE_ASR_WS_URL=wss://asr.dravachat.com
VITE_ASR_HTTP_URL=https://milo-nkadyqbsdu.cn-shanghai.fcapp.run/transcribe
